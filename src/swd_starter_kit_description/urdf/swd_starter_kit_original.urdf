<!-- SWD Starter Kit URDF with colored materials -->

<robot name="swd_starter_kit">

  <!-- ========= GLOBAL MATERIALS ========= -->
  <material name="body_dark_grey">
    <color rgba="0.20 0.20 0.22 1.0"/>
  </material>

  <material name="body_light_grey">
    <color rgba="0.70 0.70 0.72 1.0"/>
  </material>

  <material name="wheel_orange">
    <color rgba="0.90 0.55 0.15 1.0"/>
  </material>

  <material name="sensor_yellow">
    <color rgba="0.95 0.80 0.20 1.0"/>
  </material>

  <material name="sensor_black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>

  <material name="caster_white">
    <color rgba="0.95 0.95 0.95 1.0"/>
  </material>

  <material name="acrylic_clear">
    <!-- transparent top plate -->
    <color rgba="0.95 0.95 0.95 0.25"/>
  </material>

  <!-- ========= BASE FOOTPRINT ========= -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link" />
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ========= BASE LINK (METAL BODY + TOP PLATE) ========= -->
  <link name="base_link">
    <!-- main body mesh -->
    <visual>
      <origin xyz="-0.46 -0.27 0.0" rpy="0 0 0" />
      <geometry>
        <mesh
            filename="package://swd_starter_kit_description/meshes/starter_kit_base.stl"
            scale="0.001 0.001 0.001" />
      </geometry>
      <material name="body_dark_grey"/>
    </visual>

    <!-- simple transparent top plate (approximation of acrylic cover) -->
    <visual>
      <!-- adjust xyz/size if you want it tighter -->
      <origin xyz="-0.05 0 0.18" rpy="0 0 0"/>
      <geometry>
        <box size="0.55 0.40 0.01"/>
      </geometry>
      <material name="acrylic_clear"/>
    </visual>

    <collision>
      <origin xyz="-0.46 -0.27 0.0" rpy="0 0 0" />
      <geometry>
        <mesh
            filename="package://swd_starter_kit_description/meshes/starter_kit_base.stl"
            scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="-0.05 0 0" rpy="0 0 0"/>
      <mass value="27"/>
      <inertia ixx="0.70673" ixy="0.0" ixz="0.0"
               iyy="0.70673" iyz="0.0"
               izz="1.31220" />
    </inertial>
  </link>

  <!-- ========= DRIVE WHEELS ========= -->
  <joint name="base_swd_left_joint" type="continuous">
    <parent link="base_link" />
    <child link="swd_left_link" />
    <origin xyz="0.0 0.25 0.08" rpy="-1.57 0 0" />
    <axis xyz="0 0 1" />
  </joint>

  <link name="swd_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <geometry>
        <mesh filename="package://swd_starter_kit_description/meshes/wheels/starter_kit_left_tire.stl"
               scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="wheel_orange"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.037" radius="0.0630"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="1" />
      <inertia ixx="0.00111" ixy="0.0" ixz="0.0"
               iyy="0.00111" iyz="0.0"
               izz="0.00198" />
    </inertial>
  </link>

  <joint name="base_swd_right_joint" type="continuous">
    <parent link="base_link" />
    <child link="swd_right_link" />
    <origin xyz="0.0 -0.25 0.08" rpy="-1.57 0 0" />
    <axis xyz="0 0 1" />
  </joint>

  <link name="swd_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <geometry>
        <mesh filename="package://swd_starter_kit_description/meshes/wheels/starter_kit_right_tire.stl"
               scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="wheel_orange"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.037" radius="0.0630"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="1" />
      <inertia ixx="0.00111" ixy="0.0" ixz="0.0"
               iyy="0.00111" iyz="0.0"
               izz="0.00198" />
    </inertial>
  </link>

  <!-- ========= REAR CASTERS ========= -->
  <joint name="caster_back_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_back_right_link"/>
    <origin xyz="-0.35 -0.17 0.025" rpy="0 0 0"/>
  </joint>

  <link name="caster_back_right_link">
    <visual>
      <origin xyz="0 0.001 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.013"/>
      </geometry>
      <material name="caster_white"/>
    </visual>

    <collision>
      <origin xyz="0 0.001 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="0.005" />
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001" />
    </inertial>
  </link>

  <joint name="caster_back_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_back_left_link"/>
    <origin xyz="-0.35 0.17 0.025" rpy="0 0 0"/>
  </joint>

  <link name="caster_back_left_link">
    <visual>
      <origin xyz="0 0.001 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.013"/>
      </geometry>
      <material name="caster_white"/>
    </visual>

    <collision>
      <origin xyz="0 0.001 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="0.005" />
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001" />
    </inertial>
  </link>

  <!-- ========= GAZEBO FRICTION + DIFF DRIVE PLUGIN ========= -->
  <gazebo reference="swd_left_link">
    <mu1>0.7</mu1>
    <mu2>0.7</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <fdir1>1 0 0</fdir1>
    <material>Gazebo/Yellow</material>
  </gazebo>

  <gazebo reference="swd_right_link">
    <mu1>0.7</mu1>
    <mu2>0.7</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <fdir1>1 0 0</fdir1>
    <material>Gazebo/Yellow</material>
  </gazebo>

  <gazebo reference="caster_back_right_link">
    <mu1>0.05</mu1>
    <mu2>0.05</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
    <material>Gazebo/FlatBlack</material>
  </gazebo>

  <gazebo reference="caster_back_left_link">
    <mu1>0.05</mu1>
    <mu2>0.05</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
    <material>Gazebo/FlatBlack</material>
  </gazebo>

  <gazebo>
    <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <commandTopic>/swd_diff_drive_controller/cmd_vel</commandTopic>
      <odometryTopic>/swd_diff_drive_controller/odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <odometrySource>world</odometrySource>
      <publishOdomTF>true</publishOdomTF>
      <robotBaseFrame>base_link</robotBaseFrame>
      <publishWheelTF>false</publishWheelTF>
      <publishTf>true</publishTf>
      <publishWheelJointState>true</publishWheelJointState>
      <legacyMode>false</legacyMode>
      <updateRate>30</updateRate>
      <leftJoint>base_swd_left_joint</leftJoint>
      <rightJoint>base_swd_right_joint</rightJoint>
      <wheelSeparation>0.485</wheelSeparation>
      <wheelDiameter>0.125</wheelDiameter>
      <wheelAcceleration>11</wheelAcceleration>
      <wheelTorque>37</wheelTorque>
      <rosDebugLevel>na</rosDebugLevel>
    </plugin>
  </gazebo>

  <!-- ========= LIDAR ========= -->
  <joint name="base_laser" type="fixed">
    <origin xyz="0.05 0 0.2" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="laser" />
    <axis xyz="0 0 0" />
  </joint>

  <link name="laser">
    <!-- simple two-part visual: black base + yellow top -->
    <visual>
      <origin xyz="0 0 -0.01" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.045"/>
      </geometry>
      <material name="sensor_black"/>
    </visual>

    <visual>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.055"/>
      </geometry>
      <material name="sensor_yellow"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.055"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.1" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001" />
    </inertial>
  </link>

  <gazebo reference="laser">
    <material>Gazebo/FlatBlack</material>
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>30</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1080</samples>
            <resolution>1</resolution>
            <min_angle>-2.356194496154785</min_angle>
            <max_angle>2.356194496154785</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.09</min>
          <max>20</max>
          <resolution>0.001</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="laser_controller" filename="libgazebo_ros_laser.so">
        <topicName>scan</topicName>
        <frameName>laser</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ========= CAMERA (BLACK BOX STUB) ========= -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="-0.05 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 0 0"/>
    <limit lower="0" upper="0" effort="0" velocity="0"/>
  </joint>

  <link name="camera_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>

    <!-- replaced missing tbot_sim Kinect mesh with a simple black box -->
    <collision name="kinect_collision">
      <origin xyz="0.03 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.073 0.276 0.072"/>
      </geometry>
    </collision>

    <visual name="kinect_visual">
      <origin xyz="0.03 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.073 0.276 0.072"/>
      </geometry>
      <material name="sensor_black"/>
    </visual>
  </link>

</robot>

